@page "/dashboard"

@using BuildIntegrityAnalyzer.Models
@using BuildIntegrityAnalyzer.Services

<h1 style="margin-bottom:30px;">
    Intelligent Build Integrity Dashboard
</h1>

<div style="display:flex;
    gap:20px;
    margin-bottom:30px;">

    <div style="
        flex:1;
        padding:20px;
        background:#d4edda;
        border-radius:10px;">

        <h3>📊 Integrity Score</h3>

        <h1>@integrityScore%</h1>

    </div>

    <div style="
        flex:1;
        padding:20px;
        background:#f8d7da;
        border-radius:10px;">

        <h3>⚠ Total Issues</h3>

        <h1>@issues.Count</h1>

    </div>

</div>

<div style="
    padding:20px;
    background:#ffffff;
    border-radius:10px;
    box-shadow:0px 0px 10px lightgray;">

    <h3 style="margin-bottom:20px;">
        Detected Issues
    </h3>

    <table class="table table-striped">

        <thead>
            <tr>
                <th>Issue Type</th>
                <th>File</th>
                <th>Message</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var issue in issues)
            {
                <tr>
                    <td>@issue.IssueType</td>
                    <td>@issue.FileName</td>
                    <td>@issue.Message</td>
                </tr>
            }

        </tbody>

    </table>

</div>

<div style="
    margin-top:30px;
    padding:20px;
    background:#cce5ff;
    border-radius:10px;">

    <h3>📡 Monitoring Status</h3>

    <p>
        Real-time project monitoring active
    </p>

</div>

@code {

    private List<IntegrityIssue> issues =
        new();

    private int integrityScore = 100;

    protected override void OnInitialized()
    {
        var databaseService =
            new DatabaseService();

        issues = databaseService.GetIssues();

        integrityScore =
            100 - (issues.Count * 5);

        if (integrityScore < 0)
            integrityScore = 0;
    }
}